    <div class="parameters-panel hidden">
      <div class="parameters-header">openscad-parameters</div>
      <div class="parameters-body"></div>
    </div>
  </div>
  <div class="splitter" role="separator" aria-label="Resize panels"></div>
  <div class="editor-container">
    <div class="buttons"><button class="render">openscad-render</button></div>
    <code-input class="editor line-numbers" language="clike" template="openscad-highlighted">cube([20,20,20], center=true);</code-input><textarea class="parameters" placeholder="{&#x22;size&#x22;: 20, &#x22;height&#x22;: 10}">{}</textarea>
    <div class="buttons bottom"><button class="copy">openscad-copy</button><button class="download-stl">openscad-download-stl</button><button class="reset">openscad-reset</button><button class="fullscreen" title="ide-fullscreen-enter" aria-label="ide-fullscreen-enter">⛶</button></div>
  </div>
</div>
"
